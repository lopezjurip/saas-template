#!/usr/bin/env bash
# proxied — run a single command routed through the residential SOCKS5 proxy on Tailscale.
#
# Usage:
#   PROXY_HOST=laptop proxied curl https://api.ipify.org
#   PROXY_HOST=100.101.102.103 PROXY_PORT=1080 proxied python scrape.py
#
# Only this command (and its children) inherit the proxy env vars — nothing else on the host
# is affected. See skills/my-proxy/SKILL.md for details.
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: PROXY_HOST=<tailscale-ip-or-name> proxied <command> [args...]" >&2
  exit 64
fi

host="${PROXY_HOST:-laptop}"   # MagicDNS name by default; override with the 100.x.y.z IP
port="${PROXY_PORT:-1080}"

# socks5h => DNS is also resolved at the laptop, so lookups egress through the home connection.
url="socks5h://${host}:${port}"

export ALL_PROXY="$url" all_proxy="$url"
export HTTP_PROXY="$url" http_proxy="$url"
export HTTPS_PROXY="$url" https_proxy="$url"

exec "$@"
