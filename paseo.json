{
  "$schema": "https://paseo.sh/schemas/paseo.config.v1.json",
  "version": 1,
  "worktree": {
    "setup": "WORKTREE_NAME=$PASEO_BRANCH_NAME WORKTREE_PORT=$PASEO_PORT WORKTREE_ROOT_PATH=$PASEO_SOURCE_CHECKOUT_PATH WORKTREE_PROJECT=saas-template bash scripts/development/worktree-setup.sh",
    "teardown": "WORKTREE_NAME=$PASEO_BRANCH_NAME WORKTREE_PROJECT=saas-template bash scripts/development/worktree-archive.sh"
  },
  "scripts": {
    "platform": {
      "type": "service",
      "command": "pnpm run -w dev --filter={apps/platform} -- --port $PASEO_PORT"
    },
    "react-email": {
      "type": "service",
      "command": "PORT=$PASEO_PORT pnpm run -w dev --filter={packages/react-email}"
    },
    "react-pdf": {
      "type": "service",
      "command": "PORT=$PASEO_PORT pnpm run -w dev --filter={packages/react-pdf}"
    },
    "terminal": {
      "command": "bash"
    },
    "typegen": {
      "command": "pnpm run -w generate:types"
    },
    "graphql-codegen": {
      "command": "pnpm run -w generate:graphql:schema && pnpm run -w generate:graphql:platform"
    },
    "db-reset": {
      "command": "pnpm run -w db:reset"
    },
    "db-status": {
      "command": "pnpm run -w db:status"
    },
    "lint": {
      "command": "pnpm run -w format"
    },
    "lint-fix": {
      "command": "pnpm run -w format:apply"
    },
    "test": {
      "command": "pnpm run -w test"
    },
    "test-db": {
      "command": "pnpm run -w test:db"
    },
    "test-e2e": {
      "command": "pnpm run -w test:e2e"
    },
    "typecheck": {
      "command": "pnpm run -w typecheck:platform"
    }
  }
}
