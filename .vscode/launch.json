{
  "version": "0.2.0",
  "configurations": [
    // ── Attach: conecta al inspector de Next.js ya corriendo (puerto 9229) ──
    // Requiere que el servidor esté corriendo con dev:debug (--inspect flag)
    {
      "name": "Next.js: attach server (debug mode)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    },

    // ── Server-side: lanza el dev server con el inspector activo ───────────
    // Usar solo si NO está corriendo via Conductor (conflicto de puertos HTTP)
    {
      "name": "Next.js: launch server-side (standalone)",
      "type": "node-terminal",
      "request": "launch",
      "command": "NODE_OPTIONS='--inspect' pnpm dev",
      "cwd": "${workspaceFolder}/apps/platform",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },

    // ── Client-side: abre Chrome con el debugger conectado ─────────────────
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "https://lvh.me:7003",
      "webRoot": "${workspaceFolder}/apps/platform",
      "sourceMaps": true
    },

    // ── Full-stack: dev server + Chrome debugger juntos ────────────────────
    // Usar solo si NO está corriendo via Conductor
    {
      "name": "Next.js: debug full stack (standalone)",
      "type": "node-terminal",
      "request": "launch",
      "command": "NODE_OPTIONS='--inspect' pnpm dev",
      "cwd": "${workspaceFolder}/apps/platform",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome",
        "webRoot": "${workspaceFolder}/apps/platform"
      }
    }
  ],

  "compounds": [
    {
      "name": "Next.js: server + client (compound, standalone)",
      "configurations": [
        "Next.js: launch server-side (standalone)",
        "Next.js: debug client-side"
      ],
      "stopAll": true
    },
    {
      "name": "Next.js: attach + client (Conductor)",
      "configurations": [
        "Next.js: attach server (debug mode)",
        "Next.js: debug client-side"
      ],
      "stopAll": true
    }
  ]
}
