{
  "name": "@packages/supabase",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build:dry": "tsc --noEmit",
    "db:start": "dotenvx run -f .env.supabase -- supabase start",
    "db:stop": "dotenvx run -f .env.supabase -- supabase stop",
    "db:reset": "dotenvx run -f .env.supabase -- supabase db reset",
    "db:status": "dotenvx run -f .env.supabase -- supabase status",
    "db:migrate:new": "supabase migration new",
    "db:migrate:up": "dotenvx run -f .env.supabase -- supabase migration up",
    "generate:types": "dotenvx run -f .env.supabase -- supabase gen types --lang=typescript --local --schema public > src/types.ts",
    "generate:graphql:schema": "graphql-codegen -c graphql.config.ts",
    "generate:graphql:schema:local": "graphql-codegen -c graphql.config.ts --local",
    "format": "biome check --diagnostic-level=error .",
    "test:db": "dotenvx run -f .env.supabase -- supabase test db --local"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "peerDependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.4.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "swr": "^2.0.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@packages/utils": "workspace:*"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.75.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/introspection": "^6.0.1",
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@next/env": "^16.2.9",
    "@packages/typescript-config": "workspace:*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.17",
    "graphql": "^16.9.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "supabase": "^2.107.0",
    "swr": "^2.4.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
