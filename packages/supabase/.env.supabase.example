# Copy to .env.supabase and adjust for your environment.
# Generated automatically by worktree-setup.sh / exe-dev-setup.sh / local-setup.sh.
# gitignored — never commit .env.supabase.

# Supabase project identifier (namespaces Docker containers and volumes).
SUPABASE_PROJECT_ID=saas-template

# Supabase service ports. Keep each unique per running instance.
SUPABASE_API_PORT=54321
SUPABASE_DB_PORT=54322
SUPABASE_SHADOW_PORT=54323
SUPABASE_STUDIO_PORT=54324
SUPABASE_INBUCKET_PORT=54325
SUPABASE_ANALYTICS_PORT=54326

# GoTrue auth runtime config.
SUPABASE_AUTH_SITE_URL=https://lvh.me:7003
SUPABASE_AUTH_WEBAUTHN_RP_ORIGINS=https://lvh.me:7003
SUPABASE_AUTH_ALLOW_DYNAMIC_REGISTRATION=true
