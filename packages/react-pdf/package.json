{
  "name": "@packages/react-pdf",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "dev": "PORT=${PORT:-7102} webpack serve --mode development",
    "dev:open": "PORT=${PORT:-7102} webpack serve --mode development --open",
